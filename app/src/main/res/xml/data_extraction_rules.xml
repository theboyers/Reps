<?xml version="1.0" encoding="utf-8"?>
<!-- Data extraction rules for Android 12+.
     See https://developer.android.com/about/versions/12/backup-restore#xml-changes -->
<data-extraction-rules>
    <cloud-backup>
        <!-- Back up saved routines to Google Drive via Auto Backup -->
        <include domain="sharedpref" path="reps_prefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Include when transferring to a new device -->
        <include domain="sharedpref" path="reps_prefs.xml"/>
    </device-transfer>
</data-extraction-rules>

